# Smart Contract Deployment Configuration
# Copy to .env and fill in values. Never commit .env!

# Deployer private key (KEEP SECRET)
# Anvil default account (0) — safe for local only:
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb476cac3549df72e06522651e835

# Treasury and owner — set to real addresses for testnet/mainnet
TREASURY_ADDRESS=0x70997970C51812e339D9B73b0245Ad59E1FF86f0
OWNER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# USDC address — leave blank to use the network default in deploy.sh:
#   local:   0x833589FCd6edb6E08F4c7C32d4f71B1566469C18 (Base mainnet addr, works on forks)
#   sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e (Base Sepolia USDC)
#   mainnet: 0x833589FCd6edb6E08F4c7C32d4f71B1566469C18 (Base mainnet USDC)
USDC_ADDRESS=

# RPC endpoints (optional overrides — deploy.sh has public defaults)
ANVIL_RPC=http://127.0.0.1:8545
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# For contract verification on BaseScan (optional)
ETHERSCAN_API_KEY=

# For sending emails via Resend (stripe day pass codes)
RESEND_FROM_EMAIL=
